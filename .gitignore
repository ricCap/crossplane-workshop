# Ignore agent-transient state under .claude/ (worktrees, per-machine
# settings.local.json, session caches), but track shared project config
# so contributors get the same skills, hooks, and project-level
# settings.json automatically when they clone the repo.
.claude/*
!.claude/skills/
!.claude/hooks/
!.claude/settings.json
.DS_Store
*.swp
*.swo
*.bak
.vscode/
.idea/

# Build artefacts and transient caches
docs/node_modules/
docs/build/
docs/.docusaurus/
# `go build ./...` from validator/ drops a binary at validator/validator.
# Image builds use the Dockerfile and don't go through this path, so
# the binary is only ever a local artefact.
/validator/validator

.playwright-mcp

# Per-pair kubeconfigs / shareable URLs / QR codes produced by
# `task pairs:distribute`. Contain bearer tokens — never commit.
/out/

# Helm chart dependencies in the per-vcluster bundle. Chart.lock
# pins the upstream chart's version (and SHA), so ArgoCD's
# `helm dependency build` re-fetches the same bytes at sync time.
# Vendoring the unpacked tarball adds binary noise to git history
# without improving reproducibility — same pattern every other
# chart in this repo uses (reference via `repoURL`, don't vendor).
gitops/per-vcluster-bundle/charts/.mcp.json
