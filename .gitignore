# Ignore agent-transient state under .claude/ (worktrees, local settings,
# session caches), but track shared project skills so contributors get them
# automatically when they clone the repo.
.claude/*
!.claude/skills/
.DS_Store
*.swp
*.swo
*.bak
.vscode/
.idea/

# Build artefacts and transient caches
docs/node_modules/
docs/build/
docs/.docusaurus/

.playwright-mcp